# clip-watcher configuration
# Copy this to .env and fill in your values

# Nextcloud credentials (use an app password, not your main password)
NC_USER=your-username
NC_PASS=your-app-password

# Optional: override defaults
# WATCH_DIR=/path/to/your/recordings
# NC_UPLOAD_PATH=/Videos/clips
# NCEMBED_DOMAIN=share.yournextcloud.com

# Samba shares (local network mounts — much faster than WebDAV for large files)
# These should map to the same Nextcloud directories. First available is used.
# Add your Samba mount paths here, one per line.
# SAMBA_SHARES=(
#     "/Volumes/UGREENNVME-Share/nextcloud"
#     "/Volumes/ToshibaHD-Share/nextcloud"
# )
