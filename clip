#!/bin/bash
# Clip Watcher - Unified macOS Service
# Menu bar app + file watcher in one
#
# DEPRECATED: This shell wrapper is superseded by the native Swift app.
# Run ClipWatcher.swift directly instead:
#   swift ClipWatcher.swift setup   # first-time config
#   swift ClipWatcher.swift         # launches menu bar app + watcher

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLIP_WATCHER="$SCRIPT_DIR/ClipWatcher.swift"

# ── Configuration ────────────────────────────────────────────────────────────

CONFIG_DIR="$HOME/.config/clip-watcher"
CONFIG_FILE="$CONFIG_DIR/config.json"
TEMP_DIR="$HOME/Movies/Captures/encoded"
PID_FILE="$TEMP_DIR/.clip-watcher.pid"
LOG_FILE="$TEMP_DIR/clip-watcher.log"

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_setup() {
    swift "$CLIP_WATCHER" setup
}

cmd_start() {
    # Check if config exists
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "Error: Configuration not found. Run 'clip setup' first."
        exit 1
    fi

    # Check if already running
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo "Clip Watcher is already running (PID $PID)"
            exit 0
        else
            rm -f "$PID_FILE"
        fi
    fi

    # Start as background app (menu bar + watcher)
    echo "Starting Clip Watcher..."
    nohup swift "$CLIP_WATCHER" >> "$LOG_FILE" 2>&1 &
    sleep 3

    # Verify it started
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo "Clip Watcher started (PID $PID)"
            echo "Menu bar icon: ▶ Clip"
            echo "Use 'clip status' to check, 'clip stop' to stop"
            exit 0
        fi
    fi

    echo "Failed to start Clip Watcher. Check logs: $LOG_FILE"
    exit 1
}

cmd_stop() {
    if [ ! -f "$PID_FILE" ]; then
        echo "Clip Watcher is not running (no PID file found)"
        exit 0
    fi
    PID=$(cat "$PID_FILE")
    if kill -0 "$PID" 2>/dev/null; then
        echo "Stopping Clip Watcher (PID $PID)..."
        kill "$PID"
        rm -f "$PID_FILE"
        echo "Stopped."
    else
        echo "Clip Watcher is not running (stale PID $PID)"
        rm -f "$PID_FILE"
    fi
    exit 0
}

cmd_status() {
    echo ""
    echo "  ── Clip Watcher status ─────────────────────────────────"

    # Process
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo "  Status:  running (PID $PID)"
        else
            echo "  Status:  stopped (stale PID $PID)"
        fi
    else
        echo "  Status:  not running"
    fi

    # Recent uploads
    echo ""
    echo "  Recent uploads:"
    if [ -s "$TEMP_DIR/.urls" ]; then
        tail -5 "$TEMP_DIR/.urls" | while IFS=$'\t' read -r ts url fname; do
            echo "    [$ts]  $fname"
            echo "    $url"
        done
    else
        echo "    (none yet)"
    fi

    echo "  ────────────────────────────────────────────────────────"
    echo ""
    exit 0
}

cmd_last() {
    if [ ! -s "$TEMP_DIR/.urls" ]; then
        echo "No uploads recorded yet."
        exit 1
    fi
    LAST=$(tail -1 "$TEMP_DIR/.urls")
    URL=$(echo "$LAST" | cut -f2)
    FNAME=$(echo "$LAST" | cut -f3)
    echo -n "$URL" | pbcopy
    echo "Copied: $URL  ($FNAME)"
    osascript -e "display notification \"$URL\" with title \"Clip Link\" subtitle \"Copied to clipboard\""
    exit 0
}

cmd_clear() {
    > "$TEMP_DIR/.processed"
    rm -f "$TEMP_DIR"/.lock_* 2>/dev/null
    echo "Processed log cleared. All clips can be re-queued."
    exit 0
}

cmd_log() {
    if [ ! -f "$LOG_FILE" ]; then
        echo "No log file yet: $LOG_FILE"
        exit 1
    fi
    echo "Tailing $LOG_FILE  (Ctrl-C to stop)"
    tail -f "$LOG_FILE"
    exit 0
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "$1" in
    setup)  cmd_setup ;;
    start)  cmd_start ;;
    stop)   cmd_stop ;;
    status) cmd_status ;;
    last)   cmd_last ;;
    clear)  cmd_clear ;;
    log)    cmd_log ;;
    "")     cmd_start ;;
    *)      echo "Unknown command: $1"; echo "Commands: setup | start | stop | status | last | clear | log"; exit 1 ;;
esac
