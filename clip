#!/bin/bash
# Clip Watcher - Native macOS Swift Implementation
# No external dependencies required

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLIP_WATCHER="$SCRIPT_DIR/ClipWatcher.swift"
CLIP_MENU="$SCRIPT_DIR/ClipWatcherMenu.swift"

# ── Configuration ────────────────────────────────────────────────────────────

CONFIG_DIR="$HOME/.config/clip-watcher"
CONFIG_FILE="$CONFIG_DIR/config.json"
TEMP_DIR="$HOME/Movies/Captures/encoded"
PID_FILE="$TEMP_DIR/.clip-watcher.pid"
LOG_FILE="$TEMP_DIR/clip-watcher.log"

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_setup() {
    swift "$CLIP_WATCHER" setup
}

cmd_start() {
    # Check if config exists
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "Error: Configuration not found. Run 'clip setup' first."
        exit 1
    fi

    # Check if already running
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo "clip-watcher is already running (PID $PID)"
            exit 0
        else
            rm -f "$PID_FILE"
        fi
    fi

    # Start watcher in background
    echo "Starting clip-watcher..."
    nohup swift "$CLIP_WATCHER" >> "$LOG_FILE" 2>&1 &
    sleep 2

    # Verify it started
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo "clip-watcher started (PID $PID)"
            echo "Use 'clip status' to check, 'clip stop' to stop, 'clip log' to tail logs"
            exit 0
        fi
    fi

    echo "Failed to start clip-watcher. Check logs: $LOG_FILE"
    exit 1
}

cmd_stop() {
    # Stop menu bar app if running
    pkill -f "ClipWatcherMenu.swift" 2>/dev/null

    if [ ! -f "$PID_FILE" ]; then
        echo "clip-watcher is not running (no PID file found)"
        exit 0
    fi
    PID=$(cat "$PID_FILE")
    if kill -0 "$PID" 2>/dev/null; then
        echo "Stopping clip-watcher (PID $PID)..."
        kill "$PID"
        rm -f "$PID_FILE"
        echo "Stopped."
    else
        echo "clip-watcher is not running (stale PID $PID)"
        rm -f "$PID_FILE"
    fi
    exit 0
}

cmd_status() {
    echo ""
    echo "  ── clip-watcher status ─────────────────────────────────"

    # Watcher process
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo "  Watcher:  running (PID $PID)"
        else
            echo "  Watcher:  stopped (stale PID $PID)"
        fi
    else
        echo "  Watcher:  not running"
    fi

    # Recent uploads
    echo ""
    echo "  Recent uploads:"
    if [ -s "$TEMP_DIR/.urls" ]; then
        tail -5 "$TEMP_DIR/.urls" | while IFS=$'\t' read -r ts url fname; do
            echo "    [$ts]  $fname"
            echo "    $url"
        done
    else
        echo "    (none yet)"
    fi

    echo "  ────────────────────────────────────────────────────────"
    echo ""
    exit 0
}

cmd_last() {
    if [ ! -s "$TEMP_DIR/.urls" ]; then
        echo "No uploads recorded yet."
        exit 1
    fi
    LAST=$(tail -1 "$TEMP_DIR/.urls")
    URL=$(echo "$LAST" | cut -f2)
    FNAME=$(echo "$LAST" | cut -f3)
    echo -n "$URL" | pbcopy
    echo "Copied: $URL  ($FNAME)"
    osascript -e "display notification \"$URL\" with title \"Clip Link\" subtitle \"Copied to clipboard\""
    exit 0
}

cmd_clear() {
    > "$TEMP_DIR/.processed"
    rm -f "$TEMP_DIR"/.lock_* 2>/dev/null
    echo "Processed log cleared. All clips can be re-queued."
    exit 0
}

cmd_log() {
    if [ ! -f "$LOG_FILE" ]; then
        echo "No log file yet: $LOG_FILE"
        exit 1
    fi
    echo "Tailing $LOG_FILE  (Ctrl-C to stop)"
    tail -f "$LOG_FILE"
    exit 0
}

cmd_menu() {
    # Launch menu bar app in background (doesn't block terminal)
    nohup swift "$CLIP_MENU" > /dev/null 2>&1 &
    echo "Clip Watcher menu bar app started"
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "$1" in
    setup)  cmd_setup ;;
    start)  cmd_start ;;
    stop)   cmd_stop ;;
    status) cmd_status ;;
    last)   cmd_last ;;
    clear)  cmd_clear ;;
    log)    cmd_log ;;
    menu)   cmd_menu ;;
    "")     cmd_start ;;
    *)      echo "Unknown command: $1"; echo "Commands: setup | start | stop | status | last | clear | log | menu"; exit 1 ;;
esac
